# Antigence Subnet - Docker Compose Configuration
# Copy to .env and customize for your deployment.

# Bittensor network (test, finney, local)
SUBTENSOR_NETWORK=test

# Subnet UID
NETUID=1

# Wallet configuration
WALLET_NAME=default
WALLET_HOTKEY=default

# Path to bittensor wallets directory on host
# The container bind-mounts this read-only.
# macOS default: ~/.bittensor/wallets
# Linux default: ~/.bittensor/wallets
BT_WALLET_PATH=~/.bittensor/wallets

# API server port exposed to host
API_PORT=8080

# Optional: path to TOML config file (mounted into container)
# CONFIG_FILE=

# Usage:
#   docker compose --profile validator up          # validator only
#   docker compose --profile miner up              # miner only
#   docker compose --profile api up                # API server only
#   docker compose --profile validator --profile miner --profile api up  # all
#
# NOTE: Running `docker compose up` without --profile starts nothing
# because all services use profiles for selective startup.
#
# Wallet UID mismatch: If the container user (UID 1000) cannot read
# your wallet files, either:
#   1. chmod 644 your wallet key files, or
#   2. Add `user: "$(id -u):$(id -g)"` to the service in docker-compose.yml
